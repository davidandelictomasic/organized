@inherits LayoutComponentBase
@using Organized.Services
@inject UserStateService UserState
@inject NavigationManager Navigation

<nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg bg-[#1e3a5f] flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                </div>
                <a href="/" class="text-xl text-[#0a1628] font-medium no-underline hover:text-[#1e3a5f] transition-colors">Organized</a>
            </div>

            <div class="hidden md:flex items-center gap-8">
                <a href="/" class="text-gray-600 hover:text-[#1e3a5f] no-underline transition-colors">Home</a>
                <a href="/reservations" class="text-gray-600 hover:text-[#1e3a5f] no-underline transition-colors">Reservations</a>
                <a href="/my-reservations" class="text-gray-600 hover:text-[#1e3a5f] no-underline transition-colors">My Reservations</a>
            </div>

            <div class="flex items-center gap-3">
                @if (UserState.IsLoggedIn)
                {
                    <span class="text-gray-600 text-sm">@UserState.UserEmail</span>
                    <a href="/login" @onclick="HandleSignOut" class="px-4 py-2 bg-[#1e3a5f] text-white no-underline rounded-md hover:bg-[#2c5282] transition-colors">
                        Sign Out
                    </a>
                }
                else
                {
                    <a href="/login" class="px-4 py-2 text-gray-600 hover:text-[#1e3a5f] no-underline hover:bg-gray-100 rounded-md transition-colors">
                        Sign In
                    </a>
                    <a href="/register" class="px-4 py-2 bg-[#1e3a5f] text-white no-underline rounded-md hover:bg-[#2c5282] transition-colors">
                        Get Started
                    </a>
                }
            </div>
        </div>
    </div>
</nav>

@code {
    private void HandleSignOut()
    {
        UserState.ClearUser();
    }
}

<main class="pt-16">
    @Body
</main>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">??</span>
</div>
