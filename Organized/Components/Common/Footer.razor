@using Organized.Services
@inject UserStateService UserState
@inject NavigationManager Navigation

<footer class="footer-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="footer-grid">
            <div>
                <div class="footer-brand">
                    <span class="font-semibold footer-brand-text">Organized</span>
                </div>
                <p class="footer-description">
                    The smart way to manage workspace reservations. Helping teams stay organized, one desk at a time.
                </p>
            </div>

            <div>
                <h4 class="footer-heading">Quick Links</h4>
                <ul class="footer-links footer-links-two-col">
                    <li><a href="/">Home</a></li>
                    @if (!UserState.IsLoggedIn || !UserState.IsAdmin)
                    {
                        <li><a href="/reservations">Reservations</a></li>
                        <li><a href="/my-reservations">My Reservations</a></li>
                    }
                    <li><a href="/meetings">Meetings</a></li>
                    <li><a href="/achievements">Achievements</a></li>
                    <li><a href="/friends">Friends</a></li>
                    @if (UserState.IsLoggedIn && UserState.IsAdmin)
                    {
                        <li><a href="/admin">Admin Panel</a></li>
                    }
                    <li><a href="/profile">Profile</a></li>
                </ul>
            </div>

            <div>
                @if (UserState.IsLoggedIn)
                {
                    <h4 class="footer-heading">Account</h4>
                    <p class="footer-cta-text">Done for today? See you next time.</p>
                    <a href="/login" @onclick="HandleSignOut" @onclick:preventDefault="true" class="footer-cta-btn footer-cta-btn-signout">Sign Out</a>
                }
                else
                {
                    <h4 class="footer-heading">Get Started</h4>
                    <p class="footer-cta-text">Ready to organize your workspace?</p>
                    <a href="/register" class="footer-cta-btn">Create Account</a>
                }
            </div>
        </div>

        <div class="footer-bottom">
            <p>&copy; @DateTime.Now.Year Organized. Built for modern workplaces.</p>
        </div>
    </div>
</footer>

@code {
    private async Task HandleSignOut()
    {
        await UserState.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
