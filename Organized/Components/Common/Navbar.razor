@using Organized.Services
@inject UserStateService UserState
@inject NavigationManager Navigation

<nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
            <div class="flex items-center">
                <a href="/" class="text-xl font-semibold no-underline navbar-brand">Organized</a>
            </div>

            <div class="hidden md:flex items-center gap-8">
                @if (UserState.IsLoggedIn)
                {
                    <a href="/" class="text-sm font-medium no-underline transition-colors navbar-link">Home</a>
                    @if (!UserState.IsAdmin)
                    {
                        <a href="/reservations" class="text-sm font-medium no-underline transition-colors navbar-link">Reservations</a>
                        <a href="/my-reservations" class="text-sm font-medium no-underline transition-colors navbar-link">My Reservations</a>
                    }
                    <a href="/meetings" class="text-sm font-medium no-underline transition-colors navbar-link">Meetings</a>
                    <a href="/achievements" class="text-sm font-medium no-underline transition-colors navbar-link">Achievements</a>
                    <a href="/friends" class="text-sm font-medium no-underline transition-colors navbar-link">Friends</a>
                    @if (UserState.IsAdmin)
                    {
                        <a href="/admin" class="text-sm font-medium no-underline transition-colors navbar-link">Admin Panel</a>
                    }
                    <a href="/profile" class="text-sm font-medium no-underline transition-colors navbar-link">Profile</a>
                }
            </div>

            <div class="flex items-center gap-3">
                @if (UserState.IsLoggedIn)
                {
                    <a href="/login" @onclick="HandleSignOut" @onclick:preventDefault="true" class="px-4 py-2 text-white no-underline rounded-lg text-sm font-medium transition-all navbar-btn-signout">
                        Sign Out
                    </a>
                }
                else
                {
                    <a href="/login" class="px-4 py-2 no-underline rounded-lg text-sm font-medium transition-colors navbar-btn-ghost">
                        Sign In
                    </a>
                    <a href="/register" class="px-4 py-2 text-white no-underline rounded-lg text-sm font-medium transition-all navbar-btn-primary">
                        Get Started
                    </a>
                }
            </div>
        </div>
    </div>
</nav>

@code {
    private async Task HandleSignOut()
    {
        await UserState.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
