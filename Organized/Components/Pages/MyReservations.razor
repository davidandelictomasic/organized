@page "/my-reservations"
@layout HomeLayout
@using Organized.Application.Reservations
@using Organized.Components.Common.Icons
@using Organized.Domain.Enums
@using Organized.Services
@rendermode InteractiveServer
@inject GetUserReservationsRequestHandler GetReservationsHandler
@inject CancelReservationRequestHandler CancelReservationHandler
@inject UserStateService UserState
@inject NavigationManager Navigation

<PageTitle>My Reservations - Organized</PageTitle>

<div class="my-resv-page">
    <div class="my-resv-container">
        @if (UserState.IsLoggedIn)
        {
            <h1 class="my-resv-title">My Reservations</h1>

            @if (isLoading)
            {
                <div class="loading-spinner">Loading reservations...</div>
            }
            else if (reservations == null || !reservations.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-icon">
                        <CalendarIcon CssClass="my-resv-empty-svg" />
                    </div>
                    <p>You have no reservations yet.</p>
                    <a href="/reservations" class="reservation-link">Make a reservation</a>
                </div>
            }
            else
            {
                <div class="my-resv-toolbar">
                    <div class="my-resv-toolbar-left">
                        <span class="my-resv-count">@VisibleCount reservation@(VisibleCount != 1 ? "s" : "")</span>
                        <FunnelIcon CssClass="my-resv-icon-sm my-resv-toolbar-icon" />
                        <select class="my-resv-filter" @bind="statusFilter">
                            <option value="">All Status</option>
                            <option value="Pending">Pending</option>
                            <option value="Ongoing">Ongoing</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                        <button class="my-resv-sort" @onclick="ToggleSortOrder">
                            <ArrowsUpDownIcon CssClass="my-resv-icon-sm" />
                            <span>Date: @(sortAscending ? "Oldest First" : "Newest First")</span>
                        </button>
                    </div>
                    <a href="/reservations" class="my-resv-new-btn">
                        <CalendarIcon CssClass="my-resv-icon-sm" />
                        <span>New Reservation</span>
                    </a>
                </div>

                <div class="my-resv-rows">
                    @foreach (var reservation in GetVisibleReservations())
                    {
                        <div class="my-resv-row" @key="reservation.Id">
                            <div class="my-resv-row-company">
                                <div class="my-resv-row-avatar">
                                    <BuildingOfficeIcon CssClass="my-resv-icon-md" />
                                </div>
                                <div class="my-resv-row-company-text">
                                    <div class="my-resv-row-name">@reservation.TableName</div>
                                    <div class="my-resv-row-city">
                                        <MapPinIcon CssClass="my-resv-icon-xs" />
                                        <span>@reservation.City</span>
                                    </div>
                                </div>
                            </div>

                            <div class="my-resv-row-date">
                                <CalendarIcon CssClass="my-resv-icon-sm my-resv-row-meta-icon" />
                                <div class="my-resv-row-date-text">
                                    <div class="my-resv-row-date-main">@reservation.ReservationDate.ToString("MMM dd, yyyy")</div>
                                    <div class="my-resv-row-day">@reservation.ReservationDate.ToString("dddd")</div>
                                </div>
                            </div>

                            <div class="my-resv-row-time">
                                <ClockIcon CssClass="my-resv-icon-sm my-resv-row-meta-icon" />
                                <span>@reservation.ReservationDate.ToString("hh:mm tt")</span>
                            </div>

                            <div class="my-resv-row-status">
                                <span class="my-resv-badge my-resv-badge-@reservation.Status.ToString().ToLower()">
                                    @reservation.Status
                                </span>
                            </div>

                            <div class="my-resv-row-menu @(openMenuReservationId == reservation.Id ? "is-open" : "")">
                                @if (reservation.Status == ReservationStatus.Pending)
                                {
                                    <button class="my-resv-menu-btn" @onclick="() => ToggleMenu(reservation.Id)" @onclick:stopPropagation="true" title="More actions">
                                        <EllipsisVerticalIcon CssClass="my-resv-icon-sm" />
                                    </button>
                                }
                                @if (openMenuReservationId == reservation.Id)
                                {
                                    <div class="my-resv-menu" @onclick:stopPropagation="true">
                                        <button class="my-resv-menu-item" @onclick="() => HandleModify(reservation)">Modify</button>
                                        <button class="my-resv-menu-item my-resv-menu-item-danger" @onclick="() => ShowCancelModal(reservation)">Cancel Reservation</button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@if (openMenuReservationId.HasValue)
{
    <div class="my-resv-menu-backdrop" @onclick="CloseMenu"></div>
}

@if (showCancelModal && reservationToCancel != null)
{
    <div class="modal-overlay" @onclick="CloseCancelModal">
        <div class="cancel-modal" @onclick:stopPropagation="true">
            <h2 class="cancel-modal-title">Cancel Reservation</h2>
            <p class="cancel-modal-text">
                Are you sure you want to cancel your reservation for
                <strong>@reservationToCancel.TableName</strong> on
                <strong>@reservationToCancel.ReservationDate.ToString("MMM dd, yyyy")</strong>?
            </p>
            <p class="cancel-modal-warning">This action cannot be undone.</p>
            <div class="cancel-modal-actions">
                <button class="cancel-modal-back-btn" @onclick="CloseCancelModal" disabled="@isCancelling">
                    Go Back
                </button>
                <button class="cancel-modal-confirm-btn" @onclick="ConfirmCancellation" disabled="@isCancelling">
                    @if (isCancelling)
                    {
                        <span>Cancelling...</span>
                    }
                    else
                    {
                        <span>Confirm Cancellation</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ReservationResponse>? reservations;
    private bool isLoading = true;
    private bool sortAscending = false;
    private string statusFilter = "";
    private int? openMenuReservationId;
    private bool showCancelModal = false;
    private bool isCancelling = false;
    private ReservationResponse? reservationToCancel;

    private int VisibleCount => GetVisibleReservations().Count;

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsLoggedIn || !UserState.UserId.HasValue)
        {
            Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(new Uri(Navigation.Uri).PathAndQuery)}");
            return;
        }

        await LoadReservations();
    }

    private async Task LoadReservations()
    {
        isLoading = true;
        var request = new GetUserReservationsRequest
        {
            UserId = UserState.UserId!.Value
        };

        var result = await GetReservationsHandler.ProcessActiveRequestAsnync(request);
        reservations = result.Value;
        isLoading = false;
    }

    private List<ReservationResponse> GetVisibleReservations()
    {
        if (reservations == null) return new();

        IEnumerable<ReservationResponse> query = reservations;

        if (!string.IsNullOrEmpty(statusFilter))
        {
            query = query.Where(r => r.Status.ToString() == statusFilter);
        }

        query = sortAscending
            ? query.OrderBy(r => r.ReservationDate)
            : query.OrderByDescending(r => r.ReservationDate);

        return query.ToList();
    }

    private void ToggleSortOrder()
    {
        sortAscending = !sortAscending;
    }

    private void ToggleMenu(int reservationId)
    {
        openMenuReservationId = openMenuReservationId == reservationId ? null : reservationId;
    }

    private void CloseMenu()
    {
        openMenuReservationId = null;
    }

    private void HandleModify(ReservationResponse reservation)
    {
        CloseMenu();
    }

    private void ShowCancelModal(ReservationResponse reservation)
    {
        reservationToCancel = reservation;
        showCancelModal = true;
        CloseMenu();
    }

    private void CloseCancelModal()
    {
        showCancelModal = false;
        reservationToCancel = null;
        isCancelling = false;
    }

    private async Task ConfirmCancellation()
    {
        if (reservationToCancel == null || !UserState.UserId.HasValue) return;

        isCancelling = true;

        var request = new CancelReservationRequest
        {
            ReservationId = reservationToCancel.Id,
            UserId = UserState.UserId.Value
        };

        var result = await CancelReservationHandler.ProcessActiveRequestAsnync(request);

        if (result.Value?.Success == true)
        {
            await LoadReservations();
        }

        CloseCancelModal();
    }
}
