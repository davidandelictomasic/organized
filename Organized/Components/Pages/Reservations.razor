@page "/reservations"
@layout HomeLayout
@using Organized.Application.Reservations
@using Organized.Application.Tables
@using Organized.Services
@inject CreateReservationRequestHandler CreateReservationHandler
@inject GetAllTablesRequestHandler GetTablesHandler
@inject GetReservedDatesForTableRequestHandler GetReservedDatesHandler
@inject GetReservationsByDateRequestHandler GetReservationsByDateHandler
@inject UserStateService UserState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>Make a Reservation - Organized</PageTitle>

<div class="floorplan-section">
    <h1 class="floorplan-title">Make a Reservation</h1>
    <div class="floorplan-pills">
        <span class="floorplan-pill">
            <PlusCircleIcon CssClass="floorplan-pill__icon" />
            Scroll to zoom
        </span>
        <span class="floorplan-pill">
            <ArrowsPointingOutIcon CssClass="floorplan-pill__icon" />
            Drag to pan
        </span>
        <span class="floorplan-pill">
            <CheckSquareIcon CssClass="floorplan-pill__icon" />
            Click a desk to reserve
        </span>
    </div>

    @if (UserState.IsLoggedIn)
    {
        <div class="floorplan-wrapper">
            <div id="reservations-floorplan-map"></div>
        </div>

        @if (showDatePicker && floorPlanSelectedTableId > 0)
        {
            <div class="modal-overlay" @onclick="CloseModal">
                <div class="reservation-modal" @onclick:stopPropagation>
                    <div class="reservation-modal-body">
                        <div class="reservation-modal-map">
                            <div id="preview-floorplan-map"></div>
                        </div>

                        <div class="reservation-modal-form">
                            <div class="reservation-modal-header">
                                <h2 class="reservation-modal-title">Reserve @SelectedTableLabel</h2>
                                <button class="reservation-modal-close" @onclick="CloseModal" title="Close">&times;</button>
                            </div>

                            <div class="reservation-modal-content">
                                <p class="reservation-modal-label">Pick a date for your reservation</p>

                                <div class="reservation-modal-selected">
                                    <strong>Selected:</strong> @floorPlanReservationDate.ToString("MMM dd, yyyy")
                                </div>

                                <div class="reservation-modal-calendar">
                                    <DatePicker Value="floorPlanReservationDate"
                                                ValueChanged="HandleDateChanged"
                                                DisableWeekends="true"
                                                DisabledDates="reservedDatesForSelectedTable"
                                                Inline="true"
                                                CssClass="inline-datepicker" />
                                </div>

                                @if (!string.IsNullOrEmpty(message) && !isSuccess)
                                {
                                    <div class="reservation-modal-error" role="alert">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="12" r="9"></circle>
                                            <line x1="12" y1="8" x2="12" y2="13"></line>
                                            <circle cx="12" cy="16.5" r="0.6" fill="currentColor"></circle>
                                        </svg>
                                        <span>@message</span>
                                    </div>
                                }
                            </div>

                            <div class="reservation-modal-actions">
                                <button class="reservation-modal-cancel" @onclick="CloseModal">Cancel</button>
                                <button class="reservation-modal-confirm" @onclick="HandleFloorPlanSubmit" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span>Creating...</span>
                                    }
                                    else
                                    {
                                        <span>Confirm Reservation</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<CompanyTableResponse>? tables;
    private string? message;
    private bool isSuccess;

    private int floorPlanSelectedTableId = 0;
    private CompanyTableResponse? floorPlanSelectedTable;
    private DateTime floorPlanReservationDate = DateTime.Today;
    private bool showDatePicker = false;
    private bool isSubmitting = false;
    private DotNetObjectReference<Reservations>? dotNetRef;
    private bool mapInitialized = false;
    private List<string>? reservedDatesForSelectedTable;

    private const int ImageWidth = 3000;
    private const int ImageHeight = 2500;

    private List<TablePosition> tablePositions = new()
    {
        new TablePosition { TableId = 1, X = 535.5, Y = 1308 },
        new TablePosition { TableId = 2, X = 640.5, Y = 1329 },
        new TablePosition { TableId = 3, X = 740.5, Y = 1319 },
        new TablePosition { TableId = 4, X = 542, Y = 1175 },
        new TablePosition { TableId = 5, X = 644.25, Y = 1150.5 },
        new TablePosition { TableId = 6, X = 798, Y = 1149 },
        new TablePosition { TableId = 16, X = 1107.3, Y = 808.4 },
        new TablePosition { TableId = 17, X = 1106.8, Y = 898.9 },
        new TablePosition { TableId = 18, X = 1227.3, Y = 897.4 },
        new TablePosition { TableId = 19, X = 1226.8, Y = 803.9 },
        new TablePosition { TableId = 20, X = 1329.3, Y = 1019.9 },
        new TablePosition { TableId = 21, X = 1450.8, Y = 1019.4 },
        new TablePosition { TableId = 22, X = 1329.8, Y = 897.9 },
        new TablePosition { TableId = 23, X = 1450.3, Y = 898.4 },
        new TablePosition { TableId = 24, X = 1547.9, Y = 933.7 },
        new TablePosition { TableId = 25, X = 1672.1, Y = 932.9 },
        new TablePosition { TableId = 26, X = 1678.4, Y = 1119.7 },
        new TablePosition { TableId = 27, X = 1831.9, Y = 932.2 },
        new TablePosition { TableId = 28, X = 1654.4, Y = 1236.2 },
        new TablePosition { TableId = 29, X = 1895.4, Y = 1053.9 },
        new TablePosition { TableId = 30, X = 1774.6, Y = 1056.4 },
        new TablePosition { TableId = 31, X = 1995.6, Y = 975.7 },
        new TablePosition { TableId = 32, X = 1994.9, Y = 1064.7 },
        new TablePosition { TableId = 33, X = 2116.4, Y = 1062.9 },
        new TablePosition { TableId = 34, X = 2115.6, Y = 975.9 },
        new TablePosition { TableId = 35, X = 2204.9, Y = 1029.9 },
        new TablePosition { TableId = 36, X = 2325.4, Y = 1029.9 },
        new TablePosition { TableId = 37, X = 2262.4, Y = 887.4 },
        new TablePosition { TableId = 38, X = 2496.6, Y = 820.2 },
        new TablePosition { TableId = 39, X = 2612.4, Y = 860.9 },
        new TablePosition { TableId = 40, X = 2424.4, Y = 939.7 },
        new TablePosition { TableId = 41, X = 2612.4, Y = 1014.7 },
    };

    private string SelectedTableLabel
    {
        get
        {
            var pos = tablePositions.FirstOrDefault(p => p.TableId == floorPlanSelectedTableId);
            return pos?.Label ?? $"Table {floorPlanSelectedTableId}";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsLoggedIn)
        {
            Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(new Uri(Navigation.Uri).PathAndQuery)}");
            return;
        }

        var result = await GetTablesHandler.ProcessActiveRequestAsnync(new GetAllTablesRequest());
        tables = result.Value;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && UserState.IsLoggedIn && !mapInitialized)
        {
            await InitializeMap();
        }
    }

    private async Task InitializeMap()
    {
        try
        {
            await Task.Delay(200);

            dotNetRef = DotNetObjectReference.Create(this);

            await JSRuntime.InvokeVoidAsync("ReservationsFloorPlan.initialize",
                "groundplan.jpg", ImageWidth, ImageHeight, dotNetRef);

            if (tables != null)
            {
                foreach (var pos in tablePositions)
                {
                    var tableInfo = tables.FirstOrDefault(t => t.Id == pos.TableId);
                    if (tableInfo != null)
                    {
                        await JSRuntime.InvokeVoidAsync("ReservationsFloorPlan.addMarker",
                            pos.TableId, pos.X, pos.Y,
                            pos.Label, dotNetRef);
                    }
                }
            }

            mapInitialized = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing map: {ex.Message}");
        }
    }

    [JSInvokable]
    public async Task OnMarkerClicked(int tableId)
    {
        floorPlanSelectedTableId = tableId;
        floorPlanSelectedTable = tables?.FirstOrDefault(t => t.Id == tableId);
        message = null;

        var datesResult = await GetReservedDatesHandler.ProcessActiveRequestAsnync(
            new GetReservedDatesForTableRequest { TableId = tableId });
        reservedDatesForSelectedTable = (datesResult.Value ?? new List<DateTime>())
            .Select(d => d.ToString("yyyy-MM-dd"))
            .ToList();

        floorPlanReservationDate = NextAvailableDate(DateTime.Today, datesResult.Value ?? new List<DateTime>());

        showDatePicker = true;

        await JSRuntime.InvokeVoidAsync("ReservationsFloorPlan.highlightMarker", tableId);

        StateHasChanged();

        await Task.Delay(100);
        var markerData = tablePositions.Select(p => new { tableId = p.TableId, x = p.X, y = p.Y, label = p.Label }).ToArray();
        await JSRuntime.InvokeVoidAsync("ReservationsFloorPlan.initializePreview",
            "preview-floorplan-map", "groundplan.jpg", ImageWidth, ImageHeight, markerData, tableId, dotNetRef);

        await LoadOccupantsForDate(floorPlanReservationDate);
    }

    [JSInvokable]
    public async Task OnPreviewMarkerClicked(int tableId)
    {
        if (tableId == floorPlanSelectedTableId) return;

        floorPlanSelectedTableId = tableId;
        floorPlanSelectedTable = tables?.FirstOrDefault(t => t.Id == tableId);

        var datesResult = await GetReservedDatesHandler.ProcessActiveRequestAsnync(
            new GetReservedDatesForTableRequest { TableId = tableId });
        var blocked = datesResult.Value ?? new List<DateTime>();
        reservedDatesForSelectedTable = blocked
            .Select(d => d.ToString("yyyy-MM-dd"))
            .ToList();

        if (blocked.Any(d => d.Date == floorPlanReservationDate.Date))
        {
            message = $"{SelectedTableLabel} is reserved on {floorPlanReservationDate:MMM dd, yyyy}. Pick a different date.";
            isSuccess = false;
        }
        else
        {
            message = null;
        }

        StateHasChanged();

        await LoadOccupantsForDate(floorPlanReservationDate);
    }

    private async Task HandleDateChanged(DateTime date)
    {
        floorPlanReservationDate = date;
        message = null;
        await LoadOccupantsForDate(date);
    }

    private async Task LoadOccupantsForDate(DateTime date)
    {
        var result = await GetReservationsByDateHandler.ProcessActiveRequestAsnync(
            new GetReservationsByDateRequest { Date = date });
        var occupants = (result.Value ?? new List<ReservationOccupantResponse>())
            .Select(o => new
            {
                tableId = o.TableId,
                userId = o.UserId,
                userName = o.UserName,
                initials = GetInitials(o.UserName)
            })
            .ToArray();

        await JSRuntime.InvokeVoidAsync("ReservationsFloorPlan.updatePreviewOccupants",
            occupants, UserState.UserId ?? 0, floorPlanSelectedTableId);
    }

    private static DateTime NextAvailableDate(DateTime start, List<DateTime> blocked)
    {
        var blockedSet = new HashSet<DateTime>(blocked.Select(d => d.Date));
        var candidate = start.Date;
        for (int i = 0; i < 365; i++)
        {
            var isWeekend = candidate.DayOfWeek == DayOfWeek.Saturday || candidate.DayOfWeek == DayOfWeek.Sunday;
            if (!isWeekend && !blockedSet.Contains(candidate)) return candidate;
            candidate = candidate.AddDays(1);
        }
        return start.Date;
    }

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return $"{char.ToUpper(parts[0][0])}{char.ToUpper(parts[^1][0])}";
        return parts[0].Length >= 2
            ? $"{char.ToUpper(parts[0][0])}{char.ToUpper(parts[0][1])}"
            : parts[0][0].ToString().ToUpper();
    }

    private async Task CloseModal()
    {
        await JSRuntime.InvokeVoidAsync("ReservationsFloorPlan.disposePreview");

        showDatePicker = false;
        floorPlanSelectedTableId = 0;
        floorPlanSelectedTable = null;
        reservedDatesForSelectedTable = null;

        await JSRuntime.InvokeVoidAsync("ReservationsFloorPlan.clearHighlights");
    }

    private async Task HandleFloorPlanSubmit()
    {
        if (floorPlanSelectedTableId == 0)
        {
            message = "Please select a table.";
            isSuccess = false;
            return;
        }

        if (!UserState.UserId.HasValue)
        {
            message = "User not logged in.";
            isSuccess = false;
            return;
        }

        isSubmitting = true;

        try
        {
            var request = new CreateReservationRequest
            {
                UserId = UserState.UserId.Value,
                TableId = floorPlanSelectedTableId,
                ReservationDate = DateTime.SpecifyKind(floorPlanReservationDate, DateTimeKind.Utc)
            };

            var result = await CreateReservationHandler.ProcessActiveRequestAsnync(request);

            if (result.Value?.Success == true)
            {
                message = $"Reservation created successfully for Table {floorPlanSelectedTableId}! Reservation ID: {result.Value.Id}";
                isSuccess = true;
                await CloseModal();
                floorPlanReservationDate = DateTime.Today;
            }
            else
            {
                message = result.Value?.Message ?? "Failed to create reservation.";
                isSuccess = false;
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("ReservationsFloorPlan.dispose");
        }
        catch { }

        dotNetRef?.Dispose();
    }

    private class TablePosition
    {
        public int TableId { get; set; }
        public double X { get; set; }
        public double Y { get; set; }
        public bool IsMeetingRoom { get; set; }
        public string Label => IsMeetingRoom ? "Meeting Room" : $"Desk {TableId}";
    }
}
