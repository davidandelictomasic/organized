@page "/login"
@layout AuthLayout
@using Organized.Application.Users.User
@using Organized.Services
@inject GetUserByEmailRequestHandler LoginHandler
@inject UserStateService UserState
@inject NavigationManager Navigation

<div class="auth-card">
    <h1 class="auth-card__title">Welcome Back</h1>
    <p class="auth-card__lede">Sign in to continue to your workspace</p>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="auth-message auth-message--error">@errorMessage</div>
    }

    <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="loginForm">
        <div class="auth-field">
            <label class="auth-field__label" for="LoginEmail">Email</label>
            <div class="auth-field__wrap">
                <span class="auth-field__icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                        <path d="M3 7l9 6 9-6"></path>
                    </svg>
                </span>
                <InputText @bind-Value="loginModel!.Email" id="LoginEmail" class="auth-input" placeholder="you@company.com" autocomplete="email" />
            </div>
        </div>

        <div class="auth-field">
            <label class="auth-field__label" for="LoginPassword">Password</label>
            <div class="auth-field__wrap">
                <span class="auth-field__icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="4" y="11" width="16" height="10" rx="2"></rect>
                        <path d="M8 11V8a4 4 0 0 1 8 0v3"></path>
                    </svg>
                </span>
                <InputText @bind-Value="loginModel!.Password" id="LoginPassword" class="auth-input" type="@(showPassword ? "text" : "password")" placeholder="Enter your password" autocomplete="current-password" />
                <button class="auth-field__toggle" type="button" @onclick="TogglePassword" aria-label="Toggle password visibility">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                </button>
            </div>
        </div>

        <button type="submit" class="auth-btn" disabled="@isLoading">
            @if (isLoading)
            {
                <span>Signing in...</span>
            }
            else
            {
                <span>Sign In</span>
            }
        </button>

        <div class="auth-divider">or continue with</div>

        <button type="button" class="auth-social">Google</button>
    </EditForm>

    <div class="auth-foot">
        Don't have an account? <a class="auth-link" href="/register">Create account</a>
    </div>
</div>

@code {
    public class LoginModel
    {
        public string? Email { get; set; }
        public string? Password { get; set; }
    }

    [SupplyParameterFromForm]
    public LoginModel? loginModel { get; set; } = new();

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string? errorMessage;
    private bool isLoading;
    private bool showPassword;

    private void TogglePassword() => showPassword = !showPassword;

    private string GetSafeReturnUrl()
    {
        if (string.IsNullOrEmpty(ReturnUrl)) return "/";
        if (!ReturnUrl.StartsWith('/') || ReturnUrl.StartsWith("//")) return "/";
        return ReturnUrl;
    }

    private async Task HandleLogin(EditContext context)
    {
        if (isLoading) return;

        if (string.IsNullOrWhiteSpace(loginModel!.Email) ||
            string.IsNullOrWhiteSpace(loginModel!.Password))
        {
            errorMessage = "Please fill in all fields.";
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            var request = new GetUserByEmailRequest
            {
                Email = loginModel!.Email,
                Password = loginModel!.Password
            };
            var result = await LoginHandler.ProcessActiveRequestAsnync(request);

            if (result.Value?.Found == true && result.Value.PasswordMatch)
            {
                await UserState.LoginAsync(result.Value.Id, result.Value.Email, result.Value.Name, result.Value.Role);
                Navigation.NavigateTo(GetSafeReturnUrl());
            }
            else if (result.Value?.Found == true && !result.Value.PasswordMatch)
            {
                errorMessage = "Invalid password.";
            }
            else
            {
                errorMessage = "User not found.";
            }
        }
        finally
        {
            isLoading = false;
        }
    }
}
