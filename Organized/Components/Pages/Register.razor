@page "/register"
@layout AuthLayout
@using Organized.Application.Users.User
@inject CreateUserRequestHandler CreateUserHandler
@inject NavigationManager Navigation

<div class="auth-card">
    <h1 class="auth-card__title">Create Account</h1>
    <p class="auth-card__lede">Join Organized and start booking your workspace</p>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="auth-message auth-message--error">@errorMessage</div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="auth-message auth-message--success">@successMessage</div>
    }

    <EditForm Model="userModel" OnValidSubmit="HandleRegister" FormName="registerForm">
        <div class="auth-field">
            <label class="auth-field__label" for="Name">Name</label>
            <div class="auth-field__wrap">
                <span class="auth-field__icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="8" r="4"></circle>
                        <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"></path>
                    </svg>
                </span>
                <InputText @bind-Value="userModel!.Name" id="Name" class="auth-input" placeholder="Your full name" autocomplete="name" />
            </div>
        </div>

        <div class="auth-field">
            <label class="auth-field__label" for="Email">Email</label>
            <div class="auth-field__wrap">
                <span class="auth-field__icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                        <path d="M3 7l9 6 9-6"></path>
                    </svg>
                </span>
                <InputText @bind-Value="userModel!.Email" id="Email" class="auth-input" placeholder="you@company.com" autocomplete="email" />
            </div>
        </div>

        <div class="auth-field">
            <label class="auth-field__label" for="Password">Password</label>
            <div class="auth-field__wrap">
                <span class="auth-field__icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="4" y="11" width="16" height="10" rx="2"></rect>
                        <path d="M8 11V8a4 4 0 0 1 8 0v3"></path>
                    </svg>
                </span>
                <InputText @bind-Value="userModel!.Password" id="Password" class="auth-input" type="@(showPassword ? "text" : "password")" placeholder="Create a password" autocomplete="new-password" />
                <button class="auth-field__toggle" type="button" @onclick="TogglePassword" aria-label="Toggle password visibility">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                </button>
            </div>
        </div>

        <button type="submit" class="auth-btn">Create Account</button>
    </EditForm>

    <div class="auth-foot">
        Already have an account? <a class="auth-link" href="/login">Sign in</a>
    </div>
</div>

@code {
    public class UserModel
    {
        public string? Name { get; set; }
        public string? Email { get; set; }
        public string? Password { get; set; }
    }

    [SupplyParameterFromForm]
    public UserModel? userModel { get; set; } = new();

    private string? errorMessage;
    private string? successMessage;
    private bool showPassword;

    private void TogglePassword() => showPassword = !showPassword;

    private async Task HandleRegister(EditContext context)
    {
        if (string.IsNullOrWhiteSpace(userModel!.Name) ||
            string.IsNullOrWhiteSpace(userModel!.Email) ||
            string.IsNullOrWhiteSpace(userModel!.Password))
        {
            errorMessage = "Please fill in all fields.";
            return;
        }

        var request = new CreateUserRequest
        {
            Name = userModel!.Name,
            Email = userModel!.Email,
            Password = userModel!.Password
        };

        var result = await CreateUserHandler.ProcessActiveRequestAsnync(request);

        if (result.Value?.Id != null)
        {
            Navigation.NavigateTo("/login");
        }
        else
        {
            errorMessage = "Failed to create account. Please try again.";
        }
    }
}
