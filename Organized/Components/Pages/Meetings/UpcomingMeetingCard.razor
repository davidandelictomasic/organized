@using Organized.Application.Meetings

<div class="muser-card">
    <div class="muser-card__main">
        <div class="muser-card__title">@Meeting.Title</div>
        @if (!string.IsNullOrEmpty(Meeting.Description))
        {
            <div class="muser-card__desc">@Meeting.Description</div>
        }
        <div class="muser-card__meta">
            <span>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="5" width="18" height="16" rx="2"></rect>
                    <path d="M3 9h18"></path>
                </svg>
                @Meeting.MeetingDate.ToString("MMM d, yyyy") · @Meeting.MeetingDate.ToString("dddd")
            </span>
            <span>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9"></circle>
                    <polyline points="12 7 12 12 15 14"></polyline>
                </svg>
                @FormatTime(Meeting.StartTime) — @FormatTime(Meeting.EndTime)
            </span>
            @if (!string.IsNullOrEmpty(Meeting.CreatorName))
            {
                <span>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="8" r="3.2"></circle>
                        <path d="M4 20c0-3.5 3.5-6 8-6s8 2.5 8 6"></path>
                    </svg>
                    Organized by @Meeting.CreatorName
                </span>
            }
        </div>
    </div>
    <span class="muser-badge muser-badge--confirmed">
        <CheckIcon CssClass="muser-badge__icon" />
        Confirmed
    </span>
</div>

@code {
    [Parameter, EditorRequired] public UpcomingMeetingResponse Meeting { get; set; } = default!;

    private static string FormatTime(TimeSpan t) => $"{t.Hours:D2}:{t.Minutes:D2}";
}
