@using Organized.Application.Friends
@using Organized.Application.Users.User
@inject SearchUsersForMeetingRequestHandler SearchHandler

<div class="meet-search-card">
    <div class="meet-search-head">
        <h3 class="meet-search-head__title">Search for colleagues</h3>
    </div>

    <div class="meet-field__wrap">
        <span class="meet-field__icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="7"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
        </span>
        <input class="meet-input"
               placeholder="Search by name or email…"
               value="@searchTerm"
               @oninput="HandleSearchInput" />
    </div>

    <div class="meet-results">
        @if (isSearching)
        {
            <div class="meet-empty">Searching…</div>
        }
        else if (string.IsNullOrWhiteSpace(searchTerm))
        {
            <div class="meet-empty">Start typing to find colleagues.</div>
        }
        else if (results == null || results.Count == 0)
        {
            <div class="meet-empty">No users found.</div>
        }
        else
        {
            @foreach (var user in results)
            {
                var isSelected = Selected.Any(a => a.UserId == user.UserId);
                <div class="meet-result" @key="user.UserId">
                    <MeetingAvatar Name="@user.Name" />
                    <div class="meet-result__info">
                        <div class="meet-result__name">@user.Name</div>
                        <div class="meet-result__email">@user.Email</div>
                    </div>
                    @if (isSelected)
                    {
                        <span class="meet-pill meet-pill--selected">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Selected
                        </span>
                    }
                    else
                    {
                        <button class="meet-pill meet-pill--add" type="button" @onclick="() => HandleAdd(user)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                            Add
                        </button>
                    }
                </div>
            }
        }
    </div>

    <div class="meet-selected-block">
        <div class="meet-selected-block__head">
            Selected attendees
        </div>
        @if (Selected.Count == 0)
        {
            <div class="meet-empty">No attendees selected yet.</div>
        }
        else
        {
            <div class="meet-selected-block__list">
                @foreach (var a in Selected)
                {
                    <div class="meet-result" style="background:#fff; border:1px solid var(--meet-line);" @key="a.UserId">
                        <MeetingAvatar Name="@a.Name" />
                        <div class="meet-result__info">
                            <div class="meet-result__name">@a.Name</div>
                            <div class="meet-result__email">@a.Email</div>
                        </div>
                        <button class="meet-pill meet-pill--remove" type="button" @onclick="() => HandleRemove(a.UserId)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                            Remove
                        </button>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public int CurrentUserId { get; set; }
    [Parameter] public List<AttendeePick> Selected { get; set; } = new();
    [Parameter] public EventCallback<AttendeePick> OnAdd { get; set; }
    [Parameter] public EventCallback<int> OnRemove { get; set; }

    private string searchTerm = string.Empty;
    private List<UserSearchResponse>? results;
    private bool isSearching;
    private CancellationTokenSource? searchCts;

    public class AttendeePick
    {
        public int UserId { get; set; }
        public string? Name { get; set; }
        public string? Email { get; set; }
    }

    private async Task HandleSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;

        searchCts?.Cancel();
        searchCts = new CancellationTokenSource();
        var token = searchCts.Token;

        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            results = null;
            isSearching = false;
            return;
        }

        isSearching = true;

        try
        {
            await Task.Delay(200, token);
            if (token.IsCancellationRequested) return;

            var result = await SearchHandler.ProcessActiveRequestAsnync(new SearchUsersForMeetingRequest
            {
                SearcherId = CurrentUserId,
                SearchTerm = searchTerm
            });

            if (token.IsCancellationRequested) return;
            results = result.Value ?? new List<UserSearchResponse>();
        }
        catch (TaskCanceledException) { }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                isSearching = false;
            }
        }
    }

    private async Task HandleAdd(UserSearchResponse user)
    {
        await OnAdd.InvokeAsync(new AttendeePick
        {
            UserId = user.UserId,
            Name = user.Name,
            Email = user.Email
        });
    }

    private async Task HandleRemove(int userId)
    {
        await OnRemove.InvokeAsync(userId);
    }
}
