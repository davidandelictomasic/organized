@page "/"
@layout HomeLayout
@implements IDisposable
@using Organized.Services
@inject UserStateService UserState
@inject NavigationManager Navigation

<PageTitle>Home - Organized</PageTitle>

<section class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-40 -right-40 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-white/10 rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
        <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold text-white mb-4">
            Organized
        </h1>
        
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-semibold text-white/90 mb-8">
            <span>Your </span>
            <span class="inline-block min-w-[180px] text-left">
                <span class="typewriter-text border-r-4 border-white pr-1">@currentText</span>
            </span>
        </h2>

        <p class="text-xl sm:text-2xl text-white/90 mb-10 max-w-2xl mx-auto">
            The smart way to manage your workspace reservations. Book desks, rooms, and resources with ease.
        </p>

        <button @onclick="HandleGetStarted" class="inline-flex items-center px-8 py-4 text-lg font-semibold text-indigo-600 bg-white rounded-full shadow-xl hover:shadow-2xl transform hover:-translate-y-1 transition-all duration-300 cursor-pointer border-none text-decoration-none">
            Get Started
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
        </button>
    </div>
</section>

<section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Why Choose Organized?</h2>
            <p class="text-xl text-gray-600 max-w-2xl mx-auto">Simple, efficient, and designed for modern workplaces.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            <div class="text-center p-8 rounded-2xl bg-gray-50 hover:bg-indigo-50 transition-colors">
                <div class="w-16 h-16 mx-auto mb-6 bg-indigo-100 rounded-2xl flex items-center justify-center">
                    <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-3">Easy Booking</h3>
                <p class="text-gray-600">Reserve your desk or meeting room in just a few clicks.</p>
            </div>

            <div class="text-center p-8 rounded-2xl bg-gray-50 hover:bg-indigo-50 transition-colors">
                <div class="w-16 h-16 mx-auto mb-6 bg-indigo-100 rounded-2xl flex items-center justify-center">
                    <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-3">Real-time Availability</h3>
                <p class="text-gray-600">See what's available instantly and plan your day ahead.</p>
            </div>

            <div class="text-center p-8 rounded-2xl bg-gray-50 hover:bg-indigo-50 transition-colors">
                <div class="w-16 h-16 mx-auto mb-6 bg-indigo-100 rounded-2xl flex items-center justify-center">
                    <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-semibold text-gray-900 mb-3">Team Collaboration</h3>
                <p class="text-gray-600">Coordinate with your team and find each other easily.</p>
            </div>
        </div>
    </div>
</section>

@code {
private string currentText = "";
private readonly string[] phrases = { "Desk.", "Day." };
private int currentPhraseIndex = 0;
private bool isDeleting = false;
private System.Timers.Timer? typewriterTimer;

protected override void OnInitialized()
{
    StartTypewriter();
}

private void StartTypewriter()
{
    typewriterTimer = new System.Timers.Timer(100);
    typewriterTimer.Elapsed += async (sender, e) => await TypewriterTick();
    typewriterTimer.Start();
    }

    private async Task TypewriterTick()
    {
        var targetPhrase = phrases[currentPhraseIndex];

        if (!isDeleting)
        {
            if (currentText.Length < targetPhrase.Length)
            {
                currentText = targetPhrase.Substring(0, currentText.Length + 1);
                typewriterTimer!.Interval = 100;
            }
            else
            {
                typewriterTimer!.Interval = 2000;
                isDeleting = true;
            }
        }
        else
        {
            if (currentText.Length > 0)
            {
                currentText = currentText.Substring(0, currentText.Length - 1);
                typewriterTimer!.Interval = 50;
            }
            else
            {
                isDeleting = false;
                currentPhraseIndex = (currentPhraseIndex + 1) % phrases.Length;
                typewriterTimer!.Interval = 500;
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private void HandleGetStarted()
    {
        if (UserState.IsLoggedIn)
        {
            Navigation.NavigateTo("/reservations");
        }
        else
        {
            Navigation.NavigateTo("/login");
        }
    }

    public void Dispose()
    {
        typewriterTimer?.Stop();
        typewriterTimer?.Dispose();
    }
}

