@implements IDisposable
@using Organized.Services
@inject UserStateService UserState

<section id="hero" class="hero">
    <div class="hero__blob hero__blob--tr"></div>
    <div class="hero__blob hero__blob--bl"></div>

    <div class="hero__icon hero__icon--calendar" aria-hidden="true">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="5" width="18" height="16" rx="2"></rect>
            <path d="M3 9h18"></path>
            <path d="M8 3v4"></path>
            <path d="M16 3v4"></path>
        </svg>
    </div>
    <div class="hero__icon hero__icon--people" aria-hidden="true">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="9" cy="8" r="3.2"></circle>
            <circle cx="16.5" cy="9" r="2.4"></circle>
            <path d="M3.5 19c0-2.8 2.5-5 5.5-5s5.5 2.2 5.5 5"></path>
            <path d="M14.5 19c0-2 1.6-3.6 3.6-3.6s3.4 1.6 3.4 3.6"></path>
        </svg>
    </div>
    <div class="hero__icon hero__icon--bolt" aria-hidden="true">
        <svg width="48" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
            <path d="M13 3L4 14h7l-1 7 9-11h-7l1-7z"></path>
        </svg>
    </div>
    <div class="hero__icon hero__icon--chart" aria-hidden="true">
        <svg width="60" height="48" viewBox="0 0 24 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 14l5-6 4 3 5-7 6 8"></path>
        </svg>
    </div>

    <div class="hero__inner">
        <h1 class="hero__title">Organized</h1>
        <h2 class="hero__subtitle">
            Your <span class="hero__typed"><span class="typewriter-text">@currentText</span></span>
        </h2>
        <p class="hero__lede">
            The smart way to manage your workspace reservations. Book desks and plan your day with ease.
        </p>
        @if (!UserState.IsLoggedIn)
        {
            <div class="hero__ctas">
                <a href="/login" class="hero-btn hero-btn--primary">Get Started</a>
                <a href="#how-it-works" class="hero-btn hero-btn--ghost">Learn More</a>
            </div>
        }
    </div>

    <div class="hero__wave" aria-hidden="true">
        <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
            <path d="M0,80 C240,140 480,20 720,60 C960,100 1200,40 1440,80 L1440,120 L0,120 Z" fill="#f6f7fb"></path>
        </svg>
    </div>
</section>

@code {
    private string currentText = "";
    private readonly string[] phrases = { "Desk.", "Day.", "Team." };
    private int currentPhraseIndex = 0;
    private bool isDeleting = false;
    private System.Timers.Timer? typewriterTimer;

    protected override void OnInitialized()
    {
        typewriterTimer = new System.Timers.Timer(100);
        typewriterTimer.Elapsed += async (sender, e) => await TypewriterTick();
        typewriterTimer.Start();
    }

    private async Task TypewriterTick()
    {
        var targetPhrase = phrases[currentPhraseIndex];

        if (!isDeleting)
        {
            if (currentText.Length < targetPhrase.Length)
            {
                currentText = targetPhrase.Substring(0, currentText.Length + 1);
                typewriterTimer!.Interval = 100;
            }
            else
            {
                typewriterTimer!.Interval = 2000;
                isDeleting = true;
            }
        }
        else
        {
            if (currentText.Length > 0)
            {
                currentText = currentText.Substring(0, currentText.Length - 1);
                typewriterTimer!.Interval = 50;
            }
            else
            {
                isDeleting = false;
                currentPhraseIndex = (currentPhraseIndex + 1) % phrases.Length;
                typewriterTimer!.Interval = 500;
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        typewriterTimer?.Stop();
        typewriterTimer?.Dispose();
    }
}
