@implements IDisposable
@using Organized.Services
@inject UserStateService UserState
@inject NavigationManager Navigation

<section id="hero" class="hero-section min-h-screen flex items-center justify-center relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden">
        <div class="hero-blob hero-blob-1"></div>
        <div class="hero-blob hero-blob-2"></div>
        <div class="hero-dot-grid"></div>
    </div>

    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
        <h1 class="hero-title text-5xl sm:text-6xl font-bold text-white mb-4">
            Organized
        </h1>

        <h2 class="hero-subtitle text-3xl sm:text-4xl font-semibold mb-8">
            <span>Your </span>
            <span class="inline-block min-w-[180px] text-left">
                <span class="typewriter-text border-r-4 border-white pr-1">@currentText</span>
            </span>
        </h2>

        <p class="hero-description text-xl mb-10 max-w-2xl mx-auto">
            The smart way to manage your workspace reservations. Book desks and plan your day with ease.
        </p>

        <div class="hero-buttons">
            <button @onclick="HandleGetStarted" class="hero-cta inline-flex items-center px-8 py-4 text-lg font-semibold bg-white rounded-full shadow-xl transform transition-all duration-300 cursor-pointer border-none">
                Get Started
                <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
            </button>
            <a href="#how-it-works" class="hero-learn-more inline-flex items-center px-8 py-4 text-lg font-semibold rounded-full transition-all duration-300 cursor-pointer border-none">
                Learn More
                <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
            </a>
        </div>
    </div>
</section>

@code {
    private string currentText = "";
    private readonly string[] phrases = { "Desk.", "Day.", "Team." };
    private int currentPhraseIndex = 0;
    private bool isDeleting = false;
    private System.Timers.Timer? typewriterTimer;

    protected override void OnInitialized()
    {
        typewriterTimer = new System.Timers.Timer(100);
        typewriterTimer.Elapsed += async (sender, e) => await TypewriterTick();
        typewriterTimer.Start();
    }

    private async Task TypewriterTick()
    {
        var targetPhrase = phrases[currentPhraseIndex];

        if (!isDeleting)
        {
            if (currentText.Length < targetPhrase.Length)
            {
                currentText = targetPhrase.Substring(0, currentText.Length + 1);
                typewriterTimer!.Interval = 100;
            }
            else
            {
                typewriterTimer!.Interval = 2000;
                isDeleting = true;
            }
        }
        else
        {
            if (currentText.Length > 0)
            {
                currentText = currentText.Substring(0, currentText.Length - 1);
                typewriterTimer!.Interval = 50;
            }
            else
            {
                isDeleting = false;
                currentPhraseIndex = (currentPhraseIndex + 1) % phrases.Length;
                typewriterTimer!.Interval = 500;
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    private void HandleGetStarted()
    {
        if (UserState.IsLoggedIn)
            Navigation.NavigateTo("/reservations");
        else
            Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        typewriterTimer?.Stop();
        typewriterTimer?.Dispose();
    }
}
